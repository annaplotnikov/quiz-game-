<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quiz Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: linear-gradient(135deg, #fdf2f8 0%, #f3e8ff 100%);
            font-family: 'Segoe UI', 'Quicksand', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .quiz-container {
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(10px);
            border-radius: 32px;
            padding: 30px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 20px 35px rgba(249, 168, 212, 0.2);
            border: 1px solid rgba(249, 168, 212, 0.5);
        }
        h1 {
            color: #f472b6;
            text-align: center;
            margin-bottom: 20px;
            font-size: 2rem;
        }
        .question {
            font-size: 1.3rem;
            font-weight: 600;
            color: #4b5563;
            margin-bottom: 20px;
        }
        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 25px;
        }
        .option {
            background: #f9fafb;
            border: 2px solid #fbcfe8;
            border-radius: 60px;
            padding: 12px 20px;
            cursor: pointer;
            transition: all 0.2s;
            color: #374151;
            font-weight: 500;
        }
        .option:hover {
            background: #fce7f3;
            transform: translateX(5px);
        }
        .next-btn {
            background: #f472b6;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 60px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: 0.2s;
        }
        .next-btn:hover {
            background: #ec4899;
        }
        .score {
            text-align: center;
            font-size: 1.5rem;
            color: #a855f7;
            margin-top: 20px;
        }
        .restart {
            background: #a855f7;
            margin-top: 15px;
        }
        .restart:hover {
            background: #9333ea;
        }
    </style>
</head>
<body>
<div class="quiz-container" id="quizContainer">
    <h1>🌸 Quiz Game</h1>
    <div id="questionArea"></div>
</div>
<script>
    const questions = [
        { text: "What is the capital of France?", options: ["Berlin", "Madrid", "Paris", "Lisbon"], correct: 2 },
        { text: "Which language is primarily used for web development?", options: ["C++", "Python", "JavaScript", "Java"], correct: 2 },
        { text: "What does CPU stand for?", options: ["Central Processing Unit", "Computer Personal Unit", "Central Program Utility", "Core Processing Unit"], correct: 0 },
        { text: "Who wrote 'Romeo and Juliet'?", options: ["Charles Dickens", "Jane Austen", "Mark Twain", "William Shakespeare"], correct: 3 },
        { text: "What is the largest ocean on Earth?", options: ["Atlantic", "Indian", "Arctic", "Pacific"], correct: 3 }
    ];
    let current = 0;
    let score = 0;
    let answered = false;

    function render() {
        const container = document.getElementById("questionArea");
        if (current < questions.length) {
            const q = questions[current];
            let html = `<div class="question">${current+1}. ${q.text}</div><div class="options">`;
            q.options.forEach((opt, idx) => {
                html += `<div class="option" data-idx="${idx}">${String.fromCharCode(65+idx)}. ${opt}</div>`;
            });
            html += `</div><button class="next-btn" id="nextBtn">Next Question</button>`;
            container.innerHTML = html;
            document.querySelectorAll('.option').forEach(opt => {
                opt.addEventListener('click', (e) => {
                    if (answered) return;
                    const selected = parseInt(opt.dataset.idx);
                    if (selected === q.correct) {
                        score++;
                        opt.style.backgroundColor = "#86efac";
                        opt.style.borderColor = "#22c55e";
                    } else {
                        opt.style.backgroundColor = "#fecaca";
                        opt.style.borderColor = "#ef4444";
                        const correctOpt = document.querySelector(`.option[data-idx="${q.correct}"]`);
                        if (correctOpt) {
                            correctOpt.style.backgroundColor = "#86efac";
                            correctOpt.style.borderColor = "#22c55e";
                        }
                    }
                    answered = true;
                    document.querySelectorAll('.option').forEach(o => o.style.pointerEvents = 'none');
                });
            });
            document.getElementById("nextBtn").addEventListener('click', () => {
                if (!answered) {
                    alert("Please select an answer!");
                    return;
                }
                current++;
                answered = false;
                if (current < questions.length) render();
                else showResult();
            });
        }
    }

    function showResult() {
        const container = document.getElementById("quizContainer");
        container.innerHTML = `
            <h1>🌸 Quiz Complete!</h1>
            <div class="score">Your score: ${score} / ${questions.length}</div>
            <button class="next-btn restart" id="restartBtn">Play Again</button>
        `;
        document.getElementById("restartBtn").addEventListener('click', () => {
            current = 0;
            score = 0;
            answered = false;
            render();
        });
    }

    render();
</script>
</body>
</html>
